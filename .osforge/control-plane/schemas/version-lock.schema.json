{
  "$id": "osforge.control-plane.version-lock",
  "title": "OSForge Control Plane version lock (exact consumer pin)",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version", "control_plane_version", "kind", "control_plane_repository",
    "control_plane_commit", "compatibility_version", "created_by", "created_at"
  ],
  "properties": {
    "schema_version": { "type": "string", "minLength": 1, "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$" },
    "control_plane_version": { "type": "string", "minLength": 1, "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$" },
    "kind": { "type": "string", "const": "version-lock" },
    "control_plane_repository": { "type": "string", "pattern": "^[A-Za-z0-9._-]+/[A-Za-z0-9._-]+$" },
    "control_plane_commit": { "type": "string", "pattern": "^[0-9a-f]{40}$" },
    "compatibility_version": { "type": "string", "pattern": "^[0-9]+$" },
    "created_by": { "type": "string", "minLength": 1, "pattern": "^[^\\u0000-\\u001f\\u007f]{1,120}$" },
    "created_at": { "type": "string", "format": "date-time" }
  }
}
