{
  "$id": "osforge.control-plane.project",
  "title": "OSForge Control Plane project manifest (consumer repository identity)",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version", "control_plane_version", "kind", "project_id", "project_name",
    "repository", "default_branch", "control_plane_repository", "control_plane_commit",
    "adoption_phase", "security_classification", "tenant_isolation_required",
    "paid_ai_allowed", "max_remediation_loops", "human_merge_approval_required",
    "database_migration_approval_required", "feature_flag_approval_required",
    "secret_change_approval_required", "deploy_approval_required",
    "production_approval_required", "project_policy_path", "task_directory",
    "audit_directory", "approval_directory", "state_directory",
    "user_owned_untracked_paths", "created_by", "created_at"
  ],
  "properties": {
    "schema_version": { "type": "string", "minLength": 1, "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$" },
    "control_plane_version": { "type": "string", "minLength": 1, "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$" },
    "kind": { "type": "string", "const": "project" },
    "project_id": { "type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{2,63}$" },
    "project_name": { "type": "string", "minLength": 1, "pattern": "^[^\\u0000-\\u001f\\u007f]{1,120}$" },
    "repository": { "type": "string", "pattern": "^[A-Za-z0-9._-]+/[A-Za-z0-9._-]+$" },
    "default_branch": { "type": "string", "minLength": 1, "pattern": "^[A-Za-z0-9._/-]{1,120}$" },
    "control_plane_repository": { "type": "string", "pattern": "^[A-Za-z0-9._-]+/[A-Za-z0-9._-]+$" },
    "control_plane_commit": { "type": "string", "pattern": "^[0-9a-f]{40}$" },
    "adoption_phase": { "type": "string", "pattern": "^CP[0-9]+-[A-Z](\\.[0-9]+)?$" },
    "security_classification": { "type": "string", "enum": ["INTERNAL", "CONFIDENTIAL", "RESTRICTED", "CRITICAL"] },
    "tenant_isolation_required": { "type": "boolean" },
    "paid_ai_allowed": { "type": "boolean", "const": false },
    "max_remediation_loops": { "type": "integer", "minimum": 0, "maximum": 0 },
    "human_merge_approval_required": { "type": "boolean", "const": true },
    "database_migration_approval_required": { "type": "boolean", "const": true },
    "feature_flag_approval_required": { "type": "boolean", "const": true },
    "secret_change_approval_required": { "type": "boolean", "const": true },
    "deploy_approval_required": { "type": "boolean", "const": true },
    "production_approval_required": { "type": "boolean", "const": true },
    "project_policy_path": { "type": "string", "minLength": 1 },
    "task_directory": { "type": "string", "minLength": 1 },
    "audit_directory": { "type": "string", "minLength": 1 },
    "approval_directory": { "type": "string", "minLength": 1 },
    "state_directory": { "type": "string", "minLength": 1 },
    "user_owned_untracked_paths": { "type": "array", "uniqueItems": true, "items": { "type": "string", "minLength": 1 } },
    "created_by": { "type": "string", "minLength": 1, "pattern": "^[^\\u0000-\\u001f\\u007f]{1,120}$" },
    "created_at": { "type": "string", "format": "date-time" }
  }
}
