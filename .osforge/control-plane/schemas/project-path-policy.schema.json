{
  "$id": "osforge.control-plane.project-path-policy",
  "title": "OSForge Control Plane project path policy (consumer repository)",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version", "control_plane_version", "kind", "project_id",
    "allowed_paths", "forbidden_paths", "protected_paths", "migration_paths",
    "secret_paths", "production_paths", "generated_paths", "build_output_directories",
    "user_owned_untracked_paths"
  ],
  "properties": {
    "schema_version": { "type": "string", "minLength": 1, "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$" },
    "control_plane_version": { "type": "string", "minLength": 1, "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$" },
    "kind": { "type": "string", "const": "project-path-policy" },
    "project_id": { "type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{2,63}$" },
    "description": { "type": "string", "minLength": 1 },
    "build_output_directories_note": { "type": "string", "minLength": 1 },
    "allowed_paths": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "type": "string", "minLength": 1 } },
    "forbidden_paths": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "type": "string", "minLength": 1 } },
    "protected_paths": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "type": "string", "minLength": 1 } },
    "migration_paths": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "type": "string", "minLength": 1 } },
    "secret_paths": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "type": "string", "minLength": 1 } },
    "production_paths": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "type": "string", "minLength": 1 } },
    "generated_paths": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "type": "string", "minLength": 1 } },
    "build_output_directories": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "type": "string", "minLength": 1, "pattern": "^[A-Za-z0-9._-]+$" }
    },
    "user_owned_untracked_paths": { "type": "array", "uniqueItems": true, "items": { "type": "string", "minLength": 1 } }
  }
}
