{
  "$id": "osforge.control-plane.approval",
  "title": "OSForge Control Plane human approval record",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "task_id",
    "approval_type",
    "decision",
    "approved_by",
    "approved_at",
    "target_repository",
    "target_sha",
    "scope",
    "expires_at",
    "notes"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "minLength": 1
    },
    "task_id": {
      "type": "string",
      "minLength": 1
    },
    "approval_type": {
      "type": "string",
      "enum": [
        "implementation",
        "merge",
        "database_migration",
        "feature_flag_activation",
        "secret_change",
        "deploy",
        "release",
        "production_change",
        "rollback"
      ]
    },
    "decision": {
      "type": "string",
      "enum": [
        "approved",
        "rejected"
      ]
    },
    "approved_by": {
      "type": "string",
      "minLength": 1
    },
    "approved_at": {
      "type": "string",
      "format": "date-time"
    },
    "target_repository": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._-]+/[A-Za-z0-9._-]+$"
    },
    "target_sha": {
      "type": "string",
      "pattern": "^[0-9a-f]{40}$"
    },
    "scope": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "expires_at": {
      "type": "string",
      "format": "date-time"
    },
    "notes": {
      "type": "string"
    }
  }
}
