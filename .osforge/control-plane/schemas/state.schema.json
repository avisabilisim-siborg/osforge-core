{
  "$id": "osforge.control-plane.state",
  "title": "OSForge Control Plane task state",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "task_id",
    "phase",
    "updated_at",
    "evidence"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "minLength": 1
    },
    "task_id": {
      "type": "string",
      "minLength": 1
    },
    "phase": {
      "type": "string",
      "enum": [
        "planned",
        "implementing",
        "pr_open",
        "audited",
        "approved",
        "merged",
        "cleaned",
        "blocked"
      ]
    },
    "pull_request": {
      "type": "integer",
      "minimum": 1
    },
    "head_sha": {
      "type": "string",
      "pattern": "^[0-9a-f]{40}$"
    },
    "merge_commit_sha": {
      "type": "string",
      "pattern": "^[0-9a-f]{40}$"
    },
    "blocked_reason": {
      "type": "string"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    },
    "evidence": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  }
}
