{
  "$id": "osforge.control-plane.audit",
  "title": "OSForge Control Plane audit manifest",
  "description": "An audit record is bound to one repository, one pull request, one head sha and the CI runs that were observed on that exact sha. It expires, so it cannot be reused for later code.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "task_id",
    "repository",
    "pull_request",
    "audited_head_sha",
    "ci_head_sha",
    "required_ci_runs",
    "auditor_mode",
    "implementer_identity",
    "auditor_identity",
    "scope_verified",
    "history_integrity_verified",
    "required_ci_verified",
    "ruleset_prerequisites_met",
    "blocker_findings",
    "major_findings",
    "minor_findings",
    "advisory_findings",
    "database_effect_verified",
    "runtime_effect_verified",
    "feature_flag_verified",
    "secret_scan_verified",
    "paid_ai_policy_verified",
    "merge_ready",
    "human_merge_approval_required",
    "evidence",
    "audited_at",
    "audit_valid_until"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "minLength": 1
    },
    "task_id": {
      "type": "string",
      "minLength": 1
    },
    "repository": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._-]+/[A-Za-z0-9._-]+$"
    },
    "pull_request": {
      "type": "integer",
      "minimum": 1
    },
    "audited_head_sha": {
      "type": "string",
      "pattern": "^[0-9a-f]{40}$"
    },
    "ci_head_sha": {
      "type": "string",
      "pattern": "^[0-9a-f]{40}$"
    },
    "required_ci_runs": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["run_id", "workflow", "head_sha", "conclusion"],
        "properties": {
          "run_id": { "type": "string", "pattern": "^[0-9]{1,20}$" },
          "workflow": { "type": "string", "minLength": 1 },
          "head_sha": { "type": "string", "pattern": "^[0-9a-f]{40}$" },
          "conclusion": {
            "type": "string",
            "enum": ["success", "failure", "cancelled", "skipped", "timed_out", "action_required", "neutral", "stale"]
          }
        }
      }
    },
    "auditor_mode": {
      "type": "string",
      "const": "audit"
    },
    "implementer_identity": {
      "type": "string",
      "minLength": 1
    },
    "auditor_identity": {
      "type": "string",
      "minLength": 1
    },
    "scope_verified": { "type": "boolean" },
    "history_integrity_verified": { "type": "boolean" },
    "required_ci_verified": { "type": "boolean" },
    "ruleset_prerequisites_met": { "type": "boolean" },
    "blocker_findings": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "major_findings": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "minor_findings": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "advisory_findings": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "database_effect_verified": { "type": "boolean" },
    "runtime_effect_verified": { "type": "boolean" },
    "feature_flag_verified": { "type": "boolean" },
    "secret_scan_verified": { "type": "boolean" },
    "paid_ai_policy_verified": { "type": "boolean" },
    "merge_ready": { "type": "boolean" },
    "human_merge_approval_required": {
      "type": "boolean",
      "const": true
    },
    "evidence": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "audited_at": {
      "type": "string",
      "format": "date-time"
    },
    "audit_valid_until": {
      "type": "string",
      "format": "date-time"
    }
  }
}
