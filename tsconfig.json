{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "declaration": true,
    "sourceMap": true,
    "outDir": "dist",
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@osforge/protocol": [
        "packages/protocol/src/index.ts"
      ],
      "@osforge/protocol/*": [
        "packages/protocol/src/*.ts"
      ],
      "#protocol": [
        "packages/protocol/src/index.ts"
      ],
      "#policy": [
        "packages/policy/src/index.ts"
      ]
    }
  },
  "include": [
    "packages/**/*.ts"
  ]
}
